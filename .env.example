# ============================================
# PORT CONFIGURATION
# ============================================

# Vite Frontend Server Port (default: 5000)
VITE_PORT=5000

# Backend Express Server Port (default: 3001 for dev, 5000 for production)

VITE_DISABLE_HMR=true

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ============================================
# API CONFIGURATION
# ============================================

# Backend URL for API proxy (used when frontend needs to reach backend)
# Default: http://localhost:3001 (for local development)
VITE_BACKEND_URL=http://localhost:3001

# Frontend API URL (used by API client, usually relative path)
# Default: /api (works with Vite proxy)
VITE_API_URL=/api

# ============================================
# HOT MODULE REPLACEMENT (HMR) - For Development
# ============================================
# Only needed for remote development environments (Replit, Render, Railway, etc.)
# Leave these commented out for local development
#
# VITE_HMR_HOST=projectname--5000.replit.dev
# VITE_HMR_PORT=443
# VITE_HMR_PROTOCOL=wss

# ============================================
# ENVIRONMENT MODE
# ============================================

# Set to "production" for production builds
# Default: development
NODE_ENV=development

# ============================================
# EMAIL CONFIGURATION (REQUIRED FOR OTP)
# ============================================

# Gmail SMTP Configuration
# EMAIL_USER: Your Gmail address (e.g., your-email@gmail.com)
# EMAIL_PASS: Gmail App Password (NOT your regular password)
#   - To generate: Go to Google Account > Security > App passwords
#   - Select "Mail" and "Windows Computer" to get a 16-character password
#   - This is required for OTP sending to work
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# ============================================
# DEPLOYMENT ENVIRONMENT DETECTION
# ============================================
# These are automatically set by hosting platforms
# Vite will auto-detect and disable HMR if these are set
#
# REPLIT_OWNER=<set-by-replit>
# RENDER=<set-by-render>
# RAILWAY_ENVIRONMENT_NAME=<set-by-railway>
